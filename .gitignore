# See http://help.github.com/ignore-files/ for more about ignoring files.

# Build output
/dist
dist/
out/
/tmp
.turbo/
tsconfig.build.tsbuildinfo

# Dependencies
node_modules

# IDEs and editors
/.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# Test / coverage
coverage/
**/cypress/allure-results/

# Logs
*.log

# System files
.DS_Store
Thumbs.db

# Secrets / local env — never committed. User secrets live in the macOS Keychain;
# .env.example is the tracked template.
.env

# JetBrains AI assistant
.junie/

# Claude Code local files (not committed)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# CodeGraph index (local-only, rebuilt per machine)
.codegraph

# geniro working state — state.md and other generated files stay local; the
# already-tracked plan/spec/milestones, workflow, and instructions are committed.
.geniro/
!.geniro/workflow/
!.geniro/workflow/**
!.geniro/instructions/
!.geniro/instructions/**
