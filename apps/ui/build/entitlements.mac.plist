<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <!-- Hardened-runtime entitlements the Electron shell needs: JIT for V8,
       and relaxed library validation so the daemon's native addons
       (better-sqlite3, node-pty) and @napi-rs/keyring load under the
       hardened runtime. allow-dyld-environment-variables is deliberately NOT
       granted — nothing here needs the runtime to honor DYLD_*, and granting it
       alongside disable-library-validation would re-open DYLD injection the
       hardened runtime exists to block. -->
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
