{
  "name": "@geniro/app-monorepo",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "geniro — local-first macOS app for composing and running a DAG of CLI coding agents",
  "scripts": {
    "dev": "pnpm --filter @geniro/shell dev",
    "daemon:dev": "pnpm --filter @packages/daemon dev",
    "full-check": "pnpm -s build && pnpm -s check-types && pnpm -s build:tests && pnpm -s lint:fix && pnpm -s test:unit && pnpm -s test:integration",
    "build": "turbo run build",
    "build:tests": "turbo run build:tests",
    "check-types": "turbo run check-types",
    "build:packages": "turbo run build --filter='./packages/*'",
    "lint:packages": "turbo run lint --filter='./packages/*'",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:unit": "turbo run test:unit",
    "test:packages": "turbo run test --filter='./packages/*'",
    "test:packages:cov": "turbo run test:cov --filter='./packages/*'",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e --concurrency=1",
    "test:e2e:local": "turbo run test:e2e:local",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "commit": "pnpm cz",
    "prepare": "husky",
    "upgrade": "./scripts/upgrade.sh",
    "up-versions": "./scripts/up-versions.sh"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "turbo": "^2.10.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@electron/rebuild": "^4.0.6",
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "commitizen": "^4.3.2",
    "conventional-changelog-angular": "^9.2.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.3",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
