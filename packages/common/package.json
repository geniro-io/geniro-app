{
  "name": "@packages/common",
  "version": "1.2.8",
  "author": "Sergey Razumovskiy <s.razumru@gmail.com>",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "lodash": "^4.18.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "main": "dist/index.js",
  "peerDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8"
  },
  "scripts": {
    "lint:fix": "pnpm run lint --fix",
    "lint": "pnpm eslint src",
    "build": "swc src -d dist --config-file .swcrc --strip-leading-paths --ignore '**/*.spec.ts'",
    "prebuild": "rm -rf ./dist || true",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests --fileParallelism",
    "test:cov": "vitest run --coverage --passWithNoTests"
  },
  "types": "src/index.ts"
}
