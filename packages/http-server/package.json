{
  "name": "@packages/http-server",
  "version": "1.8.8",
  "author": "Sergey Razumovskiy <s.razumru@gmail.com>",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@packages/common": "workspace:*",
    "@packages/metrics": "workspace:*",
    "@scalar/nestjs-api-reference": "^1.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cls-rtracer": "^2.6.4",
    "fastify": "^5.9.0",
    "fastify-qs": "^5.0.0",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "lodash": "^4.18.1",
    "nestjs-zod": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "main": "dist/index.js",
  "peerDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@packages/common": "workspace:*",
    "@packages/metrics": "workspace:*"
  },
  "scripts": {
    "lint:fix": "pnpm run lint --fix",
    "lint": "pnpm eslint src",
    "build": "swc src -d dist --config-file ../../.swcrc --strip-leading-paths --ignore '**/*.spec.ts'",
    "prebuild": "rm -rf ./dist || true",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:unit": "vitest run --fileParallelism",
    "test:cov": "vitest run --coverage --passWithNoTests"
  },
  "types": "src/index.ts"
}
