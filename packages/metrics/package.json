{
  "name": "@packages/metrics",
  "version": "1.6.7",
  "author": "Sergey Razumovskiy <s.razumru@gmail.com>",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@packages/common": "workspace:*",
    "fastify": "^5.9.0",
    "lodash": "^4.18.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "main": "dist/index.js",
  "peerDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@packages/common": "workspace:*"
  },
  "scripts": {
    "lint:fix": "pnpm run lint --fix",
    "lint": "pnpm eslint src",
    "build": "swc src -d dist --config-file ../../.swcrc --strip-leading-paths --ignore '**/*.spec.ts'",
    "prebuild": "rm -rf ./dist || true",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:unit": "vitest run --fileParallelism",
    "test:cov": "vitest run --coverage --passWithNoTests"
  },
  "types": "src/index.ts"
}
