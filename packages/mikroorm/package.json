{
  "name": "@packages/mikroorm",
  "version": "1.0.0",
  "author": "Sergey Razumovskiy <s.razumru@gmail.com>",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@mikro-orm/core": "^7.1.5",
    "@mikro-orm/decorators": "^7.1.5",
    "@mikro-orm/migrations": "^7.1.5",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/sqlite": "^7.1.5",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@packages/common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "main": "dist/index.js",
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.0",
    "@mikro-orm/sqlite": "^7.0.0",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@packages/common": "workspace:*"
  },
  "scripts": {
    "lint:fix": "pnpm run lint --fix",
    "lint": "pnpm eslint src",
    "build": "swc src -d dist --config-file .swcrc --strip-leading-paths --ignore '**/*.spec.ts'",
    "prebuild": "rm -rf ./dist || true",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests --fileParallelism"
  },
  "types": "src/index.ts"
}
