{
  "name": "@packages/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared wire, IPC, and persistence contracts for the geniro daemon and shell",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "prebuild": "rm -rf ./dist || true",
    "check-types": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
